# Hibob Core config (HIBOB_ prefix). Copy to .env for local (host) runs.
# Inside docker-compose the values are overridden to use service names (see ai-stack compose).

# --- DB ---
HIBOB_DATABASE_DSN=postgresql://hibob:hibob_dev_pw@localhost:5433/hibob

# --- Local model (ai-stack Ollama) ---
HIBOB_OLLAMA_BASE_URL=http://localhost:11435
HIBOB_OLLAMA_DEFAULT_MODEL=gpt-oss:20b

# --- Embeddings + vector store (Phase 2) ---
HIBOB_EMBED_MODEL=nomic-embed-text
HIBOB_QDRANT_URL=http://localhost:6333

# --- Cloud model (Anthropic) ---
# Leave blank to disable cloud entirely (local-only mode).
HIBOB_ANTHROPIC_API_KEY=
HIBOB_CLOUD_DEFAULT_MODEL=claude-sonnet-4-6

# --- Cost circuit breaker (ADR 0012) ---
HIBOB_DAILY_BUDGET_USD=5.00

# --- Observability (ai-stack Phoenix); blank to disable tracing ---
HIBOB_OTLP_ENDPOINT=http://localhost:4317
